DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
# Top.gg API token (https://top.gg/bot/your-bot-id/webhooks)
TOPGG_TOKEN=your_topgg_token_here
# Comma-separated user IDs or role IDs authorized to use admin commands
AUTHORIZED_USER_IDS=your_discord_user_id_here
AUTHORIZED_ROLE_IDS=

# Audit log channel ID
AUDIT_CHANNEL_ID=
REDIS_URL=redis://localhost:6379
DISABLE_LOCAL_REDIS=false
